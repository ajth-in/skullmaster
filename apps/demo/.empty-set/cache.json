    "component": "Contact7",
    "html": "<section class=\"py-32\" data-depth=\"-1\"><div class=\"container\" data-depth=\"-1\"><div class=\"mx-auto max-w-6xl\" data-depth=\"-1\"><div class=\"mb-14\" data-depth=\"-1\"><h1 class=\"mb-4 text-4xl font-medium tracking-tight md:text-5xl\">Contact Us</h1><p class=\"text-muted-foreground\">Have a question or need assistance? Reach out through any of the channels below.</p></div><div class=\"grid gap-6 md:grid-cols-2\" data-depth=\"-1\"><div class=\"rounded-xl bg-muted/50 p-8\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-mail mb-4 size-5 text-muted-foreground\" aria-hidden=\"true\"><path d=\"m22 7-8.991 5.727a2 2 0 0 1-2.009 0L2 7\"></path><rect x=\"2\" y=\"4\" width=\"20\" height=\"16\" rx=\"2\"></rect></svg><p class=\"mb-1 font-medium\">Email</p><p class=\"mb-4 text-sm text-muted-foreground\">We respond to all emails within 24 hours.</p><a href=\"mailto:hello@example.com\" class=\"hover:underline\">hello@example.com</a></div><div class=\"rounded-xl bg-muted/50 p-8\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-map-pin mb-4 size-5 text-muted-foreground\" aria-hidden=\"true\"><path d=\"M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0\"></path><circle cx=\"12\" cy=\"10\" r=\"3\"></circle></svg><p class=\"mb-1 font-medium\">Office</p><p class=\"mb-4 text-sm text-muted-foreground\">Drop by our office for a chat.</p><a href=\"#\" class=\"hover:underline\">1 Eagle St, Brisbane, QLD, 4000</a></div><div class=\"rounded-xl bg-muted/50 p-8\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-phone mb-4 size-5 text-muted-foreground\" aria-hidden=\"true\"><path d=\"M13.832 16.568a1 1 0 0 0 1.213-.303l.355-.465A2 2 0 0 1 17 15h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2A18 18 0 0 1 2 4a2 2 0 0 1 2-2h3a2 2 0 0 1 2 2v3a2 2 0 0 1-.8 1.6l-.468.351a1 1 0 0 0-.292 1.233 14 14 0 0 0 6.392 6.384\"></path></svg><p class=\"mb-1 font-medium\">Phone</p><p class=\"mb-4 text-sm text-muted-foreground\">We're available Mon-Fri, 9am-5pm.</p><a href=\"tel:(123) 456-7890\" class=\"hover:underline\">(123) 456-7890</a></div><div class=\"rounded-xl bg-muted/50 p-8\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-message-circle mb-4 size-5 text-muted-foreground\" aria-hidden=\"true\"><path d=\"M2.992 16.342a2 2 0 0 1 .094 1.167l-1.065 3.29a1 1 0 0 0 1.236 1.168l3.413-.998a2 2 0 0 1 1.099.092 10 10 0 1 0-4.777-4.719\"></path></svg><p class=\"mb-1 font-medium\">Live Chat</p><p class=\"mb-4 text-sm text-muted-foreground\">Get instant help from our support team.</p><a href=\"#\" class=\"hover:underline\">Start Chat</a></div></div></div></div></section>",
