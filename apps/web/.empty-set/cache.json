  "feature-card-1": {
    "component": "feature-card-1",
    "html": "<div class=\"jsx-439cbb430e9df03a feature-card\"><div class=\"jsx-439cbb430e9df03a feature-icon\">⚙️</div><h3 class=\"jsx-439cbb430e9df03a feature-card-title\">Static AST Analysis</h3><p class=\"jsx-439cbb430e9df03a feature-card-desc\">Leverages ts-morph to intelligently parse your JSX layouts and extract precise dimensional styles automatically.</p></div>",
    "hash": "823530b58a8713572e6f94017997e96a0ccb6709988a3c989496a11cb783c4e7"
  },
  "feature-card-2": {
    "component": "feature-card-2",
    "html": "<div class=\"jsx-439cbb430e9df03a feature-card\"><div class=\"jsx-439cbb430e9df03a feature-icon\">⚡</div><h3 class=\"jsx-439cbb430e9df03a feature-card-title\">Real-Time Polling</h3><p class=\"jsx-439cbb430e9df03a feature-card-desc\">Listens to your local development environment and regenerates the skeleton loaders on component changes instantly.</p></div>",
    "hash": "f7591dcfd4f3ec6bec6b27a5bdb1a7a4e01dc62c5a980120dc0971d2e8b3d07b"
  },
  "feature-card-3": {
    "component": "feature-card-3",
    "html": "<div class=\"jsx-439cbb430e9df03a feature-card\"><div class=\"jsx-439cbb430e9df03a feature-icon\">📦</div><h3 class=\"jsx-439cbb430e9df03a feature-card-title\">Zero Dependency Output</h3><p class=\"jsx-439cbb430e9df03a feature-card-desc\">Generates clean, native React JSX skeletons with minimal inline styles or custom layouts, ready to be copied or auto-linked.</p></div>",
    "hash": "b36808d5364a8e209aa277a240a2bd500a531034448c8e453fc4a7e621f46636"
  },
  "features-section": {
    "component": "features-section",
    "html": "<section id=\"features\" class=\"jsx-439cbb430e9df03a features-section\"><h2 class=\"jsx-439cbb430e9df03a features-title\">Designed for Modern Workflows</h2><div class=\"jsx-439cbb430e9df03a features-grid\"><div class=\"jsx-439cbb430e9df03a feature-card\"><div class=\"jsx-439cbb430e9df03a feature-icon\">⚙️</div><h3 class=\"jsx-439cbb430e9df03a feature-card-title\">Static AST Analysis</h3><p class=\"jsx-439cbb430e9df03a feature-card-desc\">Leverages ts-morph to intelligently parse your JSX layouts and extract precise dimensional styles automatically.</p></div><div class=\"jsx-439cbb430e9df03a feature-card\"><div class=\"jsx-439cbb430e9df03a feature-icon\">⚡</div><h3 class=\"jsx-439cbb430e9df03a feature-card-title\">Real-Time Polling</h3><p class=\"jsx-439cbb430e9df03a feature-card-desc\">Listens to your local development environment and regenerates the skeleton loaders on component changes instantly.</p></div><div class=\"jsx-439cbb430e9df03a feature-card\"><div class=\"jsx-439cbb430e9df03a feature-icon\">📦</div><h3 class=\"jsx-439cbb430e9df03a feature-card-title\">Zero Dependency Output</h3><p class=\"jsx-439cbb430e9df03a feature-card-desc\">Generates clean, native React JSX skeletons with minimal inline styles or custom layouts, ready to be copied or auto-linked.</p></div></div></section>",
    "hash": "30b90d3bdb81d69803d578da9c7a4e1fb0debd9fb1e6d52898797fd7f7e4c0df"
  },
