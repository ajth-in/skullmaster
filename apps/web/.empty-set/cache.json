  "hero-section": {
    "component": "hero-section",
    "html": "<section class=\"jsx-439cbb430e9df03a hero-section\"><span class=\"jsx-439cbb430e9df03a hero-badge\">INTRODUCING CAUSTICS COMPILER</span><h1 class=\"jsx-439cbb430e9df03a hero-title\">Automated loaders.<br class=\"jsx-439cbb430e9df03a\"><span class=\"jsx-439cbb430e9df03a hero-title-gradient\">Zero Layout Shift.</span></h1><p class=\"jsx-439cbb430e9df03a hero-subtitle\">Ø-slash compiles your actual React component layout into perfect, CSS-animated skeleton screens. No more manual drawing, no more layout shifts.</p><div class=\"jsx-439cbb430e9df03a hero-cta-group\"><button class=\"jsx-439cbb430e9df03a hero-btn primary\">Get Started Free</button><button class=\"jsx-439cbb430e9df03a hero-btn secondary\">View Documentation</button></div><div class=\"jsx-439cbb430e9df03a showcase-wrapper\"><div class=\"jsx-439cbb430e9df03a tab-selector\"><button class=\"jsx-439cbb430e9df03a tab-btn active\">Actual UI</button><button class=\"jsx-439cbb430e9df03a tab-btn \">Generated Skeleton</button></div><div class=\"jsx-439cbb430e9df03a showcase-card\"><div class=\"jsx-439cbb430e9df03a profile-avatar\">Ø</div><div class=\"jsx-439cbb430e9df03a profile-details\"><h3 class=\"jsx-439cbb430e9df03a profile-name\">Caustic Compiler</h3><span class=\"jsx-439cbb430e9df03a profile-tag\">@caustics/server</span><p class=\"jsx-439cbb430e9df03a profile-bio\">Analyzing components via ts-morph and writing static loaders directly into your filesystem in real-time.</p><div class=\"jsx-439cbb430e9df03a profile-stats\"><div class=\"jsx-439cbb430e9df03a stat-item\"><span class=\"jsx-439cbb430e9df03a stat-val\">120ms</span><span class=\"jsx-439cbb430e9df03a stat-lbl\">Generation Time</span></div><div class=\"jsx-439cbb430e9df03a stat-item\"><span class=\"jsx-439cbb430e9df03a stat-val\">0px</span><span class=\"jsx-439cbb430e9df03a stat-lbl\">Layout Shift</span></div></div></div></div></div></section>",
    "hash": "52c8b6f8e8bc4ff5218f2b04cc782c5b8e2c0ae3cd748254c961fe54897480b2"
  },
  "features-title": {
    "component": "features-title",
    "html": "<h2 class=\"jsx-439cbb430e9df03a features-title\">Designed for Modern Workflows</h2>",
