    "html": "<div class=\"jsx-439cbb430e9df03a showcase-card\"><div class=\"jsx-439cbb430e9df03a profile-avatar\">Ø</div><div class=\"jsx-439cbb430e9df03a profile-details\"><h3 class=\"jsx-439cbb430e9df03a profile-name\">Caustic Compiler</h3><span class=\"jsx-439cbb430e9df03a profile-tag\">@caustics/server</span><p class=\"jsx-439cbb430e9df03a profile-bio\">Analyzing components via ts-morph and writing static loaders directly into your filesystem in real-time.</p><div class=\"jsx-439cbb430e9df03a profile-stats\"><div class=\"jsx-439cbb430e9df03a stat-item\"><span class=\"jsx-439cbb430e9df03a stat-val\">120ms</span><span class=\"jsx-439cbb430e9df03a stat-lbl\">Generation Time</span></div><div class=\"jsx-439cbb430e9df03a stat-item\"><span class=\"jsx-439cbb430e9df03a stat-val\">0px</span><span class=\"jsx-439cbb430e9df03a stat-lbl\">Layout Shift</span></div></div></div></div>",
