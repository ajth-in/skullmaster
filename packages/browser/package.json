{
  "name": "@skullmaster/browser",
  "displayName": "Skullmaster browser",
  "version": "0.0.1",
  "description": "browser extension for generating skeletons using skullmaster  \t parsers",
  "author": "Ajith Kumar P M <ajithpmuralidharan01@gmail.com>",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "lint": "oxlint -D correctness -W suspicious -W perf --config oxlint.json popup.tsx"
  },
  "dependencies": {
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@skullmaster/oxlint-config": "workspace:*",
    "@skullmaster/shared": "workspace:*",
    "@skullmaster/typescript-config": "workspace:*",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "oxlint": "^1.0.0",
    "prettier": "3.2.4",
    "typescript": "5.3.3"
  },
  "manifest": {
    "host_permissions": [
      "https://*/*"
    ]
  }
}
