{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@skullmaster/typescript-config/node-library.json",
  "compilerOptions": {
    "target": "esnext",
    "lib": ["es2023", "DOM", "DOM.Iterable"],
    "moduleDetection": "force",
    "module": "preserve",
    "resolveJsonModule": true,
    "types": ["node"],
    "verbatimModuleSyntax": true
  },
  "include": ["src"]
}
