{
  "name": "@skullmaster/react",
  "version": "0.2.0-next.4",
  "description": "A starter for creating a React component library.",
  "homepage": "https://www.ajth.in/skullmaster/",
  "bugs": {
    "url": "https://github.com/ajth-in/skullmaster/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ajth-in/skullmaster.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json",
    "./style.css": "./dist/style.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "play": "vite",
    "test": "vitest",
    "lint": "oxlint -D correctness -W suspicious -W perf --config oxlint.json src",
    "typecheck": "tsc --noEmit",
    "release": "bumpp",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.14",
    "lit": "^3.3.3",
    "react-aria-components": "^1.18.0"
  },
  "devDependencies": {
    "@skullmaster/oxlint-config": "workspace:*",
    "@skullmaster/typescript-config": "workspace:*",
    "@tsdown/css": "^0.22.3",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.5",
    "oxlint": "^1.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vitest": "^4.1.5",
    "vitest-browser-react": "^2.2.0"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  }
}
