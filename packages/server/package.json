{
  "name": "skullmaster",
  "version": "0.1.0",
  "private": false,
  "description": "A simple example library built by tsdown",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ajth-in/skullmaster.git"
  },
  "bin": {
    "skullmaster": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
