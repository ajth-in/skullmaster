    "@skullmaster/shared": "workspace:*",
    "@types/lodash": "^4.17.24",
    "c12": "4.0.0-beta.5",
    "cac": "^7.0.0",
    "execa": "^9.6.1",
    "hono": "^4.12.23",
    "jsdom": "^29.1.1",
    "lit": "^3.3.3",
    "lodash": "^4.18.1",
    "oxfmt": "^0.52.0",
    "ts-morph": "^28.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/babel__generator": "^7.27.0",
    "@types/jsdom": "^28.0.3",
